# Core Agents
DATABASE_URL=postgres://coreagents:coreagents@localhost:5432/coreagents
PORT=3001
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
JWT_SECRET=dev-secret-change-in-production
VALKEY_PASSWORD=dev-valkey
# Encryption key for secrets at rest (64 hex chars = 256-bit AES key). Generate with: openssl rand -hex 32
# SECRETS_ENCRYPTION_KEY=abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789
NEXT_PUBLIC_API_URL=http://localhost:3001/api
FRONTEND_URL=http://localhost:3000

# SSO / OIDC (optional — uncomment to enable SSO login)
# AUTH_SSO_PROVIDER=keycloak
# AUTH_SSO_CLIENT_ID=your-client-id
# AUTH_SSO_CLIENT_SECRET=your-client-secret
# AUTH_SSO_ISSUER=https://keycloak.example.com/realms/your-realm
# AUTH_SSO_REDIRECT_URI=http://localhost:3001/api/auth/sso/callback
# AUTH_ADMIN_GROUPS=core-agents-admin
# AUTH_EDITOR_GROUPS=core-agents-editor
